# NeonDB (PostgreSQL)
DATABASE_URL=postgresql://...?sslmode=require
DIRECT_DATABASE_URL=postgresql://...?sslmode=require

# Google OAuth (NextAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth
NEXTAUTH_SECRET=               # generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000/wayfarer-ai

# Google AI (Gemini)
GEMINI_API_KEY=

# Google Maps Platform (Places API + Maps JS API)
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=   # same key — exposes Maps JS API to the browser for the itinerary map
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=    # Map ID from Cloud Console → Maps Platform → Map Management
